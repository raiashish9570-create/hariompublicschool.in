# hariompublicschool.in
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Hari Om Public School – Pahalwanpur, Ghazipur</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;900&family=Hind:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --red:#c0181a;--dark-red:#8a0f10;--saffron:#e8841a;--gold:#f5c842;
  --cream:#fdf8f0;--white:#ffffff;--dark:#1a0a00;--text:#2d1a0a;
  --muted:#7a6050;--light:#fff5e6;--border:#e8d5c0;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Hind',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}

/* TICKER */
.ticker-wrap{background:var(--dark-red);padding:7px 0;overflow:hidden}
.ticker{display:flex;animation:ticker 35s linear infinite;white-space:nowrap}
.ticker span{color:var(--gold);font-size:.78rem;font-weight:600;letter-spacing:.06em;padding:0 48px}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* NAV */
nav{background:var(--white);border-bottom:3px solid var(--red);position:sticky;top:0;z-index:999;box-shadow:0 2px 16px rgba(0,0,0,.1)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:0}
.nav-logo{display:flex;align-items:center;gap:14px;text-decoration:none;padding:10px 0}
.nav-logo img{width:52px;height:52px;object-fit:contain;border-radius:50%}
.nav-logo-text .school-name{font-family:'Cinzel',serif;font-size:1rem;font-weight:900;color:var(--red);line-height:1.1}
.nav-logo-text .school-sub{font-size:.7rem;color:var(--muted);letter-spacing:.05em}
.nav-links{display:flex;gap:2px;margin-left:auto}
.nav-links a{padding:10px 14px;font-size:.8rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--text);text-decoration:none;border-radius:4px;transition:background .2s,color .2s;white-space:nowrap}
.nav-links a:hover,.nav-links a.active{background:var(--red);color:var(--white)}
.nav-admit{background:var(--red);color:var(--white)!important;border-radius:4px;margin-left:8px}
.nav-admit:hover{background:var(--dark-red)!important}

/* SECTIONS */
.page-section{display:none}
.page-section.active{display:block}

/* ══ HOME ══════════════════════════════════════════ */
.hero{
  background:linear-gradient(135deg,var(--dark-red) 0%,var(--red) 50%,#d4301a 100%);
  padding:72px 5% 60px;
  position:relative;overflow:hidden;
  display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;
  min-height:88vh;
}
.hero::before{content:'';position:absolute;right:-100px;top:-100px;width:600px;height:600px;
  border-radius:50%;background:rgba(255,255,255,.04);pointer-events:none}
.hero::after{content:'ॐ';position:absolute;right:8%;top:50%;transform:translateY(-50%);
  font-size:18rem;color:rgba(255,255,255,.04);font-family:serif;line-height:1;pointer-events:none}
.hero-left{z-index:1;animation:fadeUp .8s ease both}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);
  color:var(--gold);font-size:.75rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  padding:6px 16px;border-radius:100px;margin-bottom:22px
}
.hero h1{font-family:'Cinzel',serif;font-size:clamp(2rem,4.5vw,3.4rem);font-weight:900;
  color:var(--white);line-height:1.1;margin-bottom:10px}
.hero-slogan{font-size:1rem;color:rgba(255,255,255,.75);font-style:italic;margin-bottom:18px;
  border-left:3px solid var(--gold);padding-left:14px;line-height:1.6}
.hero-location{color:rgba(255,255,255,.55);font-size:.85rem;margin-bottom:32px;display:flex;align-items:center;gap:6px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.btn-white{background:var(--white);color:var(--red);padding:13px 28px;border-radius:6px;font-weight:700;
  text-decoration:none;font-size:.9rem;transition:transform .2s,box-shadow .2s;display:inline-block}
.btn-white:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.btn-ghost{border:2px solid rgba(255,255,255,.4);color:var(--white);padding:12px 28px;border-radius:6px;
  font-weight:600;text-decoration:none;font-size:.9rem;transition:border-color .2s,transform .2s;display:inline-block}
.btn-ghost:hover{border-color:var(--gold);transform:translateY(-2px)}
.hero-right{z-index:1;display:flex;flex-direction:column;align-items:center;gap:20px;animation:fadeUp .8s .15s ease both}
.hero-logo-circle{
  width:220px;height:220px;border-radius:50%;
  background:var(--white);
  padding:6px;box-shadow:0 20px 60px rgba(0,0,0,.3);
}
.hero-logo-circle img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.hero-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;max-width:360px}
.hero-card{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);
  border-radius:10px;padding:14px 12px;text-align:center;backdrop-filter:blur(8px);
  transition:background .2s,transform .2s}
.hero-card:hover{background:rgba(255,255,255,.17);transform:translateY(-3px)}
.hero-card .hc-icon{font-size:1.6rem;margin-bottom:6px}
.hero-card h3{color:var(--white);font-size:.82rem;font-weight:700;margin-bottom:2px}
.hero-card p{color:rgba(255,255,255,.55);font-size:.7rem}

/* STATS */
.stats-row{background:var(--dark);display:flex;justify-content:space-around;flex-wrap:wrap;padding:24px 5%;gap:20px}
.stat{text-align:center}
.stat .n{font-family:'Cinzel',serif;font-size:2rem;font-weight:900;color:var(--gold);line-height:1}
.stat .l{font-size:.7rem;color:rgba(255,255,255,.55);letter-spacing:.1em;text-transform:uppercase;margin-top:4px}

/* ABOUT ROW */
.about-strip{background:var(--white);padding:70px 5%;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.about-strip img{width:100%;max-width:380px;border-radius:50%;border:6px solid var(--red);box-shadow:0 16px 48px rgba(192,24,26,.2)}
.section-label{font-size:.72rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--red);margin-bottom:8px}
.section-h{font-family:'Cinzel',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;color:var(--dark);line-height:1.2;margin-bottom:14px}
.section-p{color:var(--muted);line-height:1.8;font-size:.95rem;margin-bottom:20px}
.pillars{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:8px}
.pillar{background:var(--light);border-left:3px solid var(--red);border-radius:6px;padding:12px 14px}
.pillar h4{font-size:.85rem;font-weight:700;color:var(--dark);margin-bottom:3px}
.pillar p{font-size:.75rem;color:var(--muted)}

/* QUICK LINKS */
.quick-links{padding:60px 5%;background:var(--cream)}
.ql-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-top:36px}
.ql-card{background:var(--white);border-radius:12px;padding:24px 20px;text-align:center;
  border:1.5px solid var(--border);cursor:pointer;transition:border-color .2s,transform .2s,box-shadow .2s}
.ql-card:hover{border-color:var(--red);transform:translateY(-4px);box-shadow:0 12px 32px rgba(192,24,26,.12)}
.ql-card .icon{font-size:2rem;margin-bottom:10px}
.ql-card h3{font-size:.9rem;font-weight:700;color:var(--dark);margin-bottom:4px}
.ql-card p{font-size:.75rem;color:var(--muted)}

/* ══ ANNOUNCEMENTS ══════════════════════════════════ */
#announcements{padding:70px 5%;background:var(--white)}
.notice-board{background:var(--light);border:2px solid var(--red);border-radius:16px;overflow:hidden;margin-top:40px}
.notice-board-header{background:var(--red);padding:16px 24px;display:flex;align-items:center;gap:12px}
.notice-board-header h3{color:var(--white);font-family:'Cinzel',serif;font-size:1.1rem;font-weight:700}
.notice-list{padding:0}
.notice-item{display:flex;gap:16px;align-items:flex-start;padding:18px 24px;
  border-bottom:1px solid var(--border);transition:background .2s}
.notice-item:last-child{border-bottom:none}
.notice-item:hover{background:rgba(192,24,26,.04)}
.notice-date{min-width:52px;text-align:center;background:var(--red);border-radius:8px;padding:8px 4px}
.notice-date .day{font-family:'Cinzel',serif;font-size:1.4rem;font-weight:900;color:var(--white);line-height:1}
.notice-date .month{font-size:.6rem;font-weight:700;color:rgba(255,255,255,.8);text-transform:uppercase}
.notice-content h4{font-size:.95rem;font-weight:700;color:var(--dark);margin-bottom:4px}
.notice-content p{font-size:.82rem;color:var(--muted);line-height:1.6}
.notice-badge{display:inline-block;padding:2px 10px;border-radius:100px;font-size:.65rem;font-weight:700;
  letter-spacing:.06em;text-transform:uppercase;margin-top:6px}
.badge-red{background:#fde8e8;color:var(--red)}
.badge-green{background:#e8f5e9;color:#2e7d32}
.badge-blue{background:#e3f2fd;color:#1565c0}
.badge-orange{background:#fff3e0;color:#e65100}

/* ══ CALENDAR ══════════════════════════════════════ */
#calendar{padding:70px 5%;background:var(--cream)}
.calendar-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-top:40px}
.cal-month{background:var(--white);border-radius:14px;overflow:hidden;border:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,.06)}
.cal-month-header{background:var(--red);padding:14px 20px;display:flex;justify-content:space-between;align-items:center}
.cal-month-header h3{color:var(--white);font-family:'Cinzel',serif;font-size:1rem;font-weight:700}
.cal-month-header span{color:rgba(255,255,255,.7);font-size:.8rem}
.cal-events{padding:0}
.cal-event{display:flex;gap:14px;align-items:center;padding:12px 18px;border-bottom:1px solid var(--border)}
.cal-event:last-child{border-bottom:none}
.cal-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.cal-event-info h4{font-size:.85rem;font-weight:600;color:var(--dark);margin-bottom:1px}
.cal-event-info p{font-size:.75rem;color:var(--muted)}
.cal-legend{display:flex;flex-wrap:wrap;gap:16px;margin-top:24px;padding:0 4px}
.cal-legend-item{display:flex;align-items:center;gap:6px;font-size:.75rem;color:var(--muted);font-weight:500}
.legend-dot{width:10px;height:10px;border-radius:50%}

/* ══ CO-CURRICULAR ══════════════════════════════════ */
#cocurricular{padding:70px 5%;background:var(--white)}
.cc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;margin-top:40px}
.cc-card{border-radius:14px;overflow:hidden;border:1.5px solid var(--border);transition:transform .25s,box-shadow .25s}
.cc-card:hover{transform:translateY(-6px);box-shadow:0 16px 40px rgba(0,0,0,.1)}
.cc-card-top{height:6px}
.cc-card-body{padding:22px 18px}
.cc-card-body .cc-icon{font-size:2.4rem;margin-bottom:12px}
.cc-card-body h3{font-size:1rem;font-weight:700;color:var(--dark);margin-bottom:6px}
.cc-card-body p{font-size:.8rem;color:var(--muted);line-height:1.6;margin-bottom:12px}
.cc-tags{display:flex;flex-wrap:wrap;gap:6px}
.cc-tag{background:var(--light);color:var(--red);font-size:.68rem;font-weight:700;
  padding:3px 10px;border-radius:100px;border:1px solid rgba(192,24,26,.2)}

/* ══ ACADEMICS ══════════════════════════════════════ */
#academics{padding:70px 5%;background:var(--cream)}
.tab-bar{display:flex;gap:4px;background:var(--white);border-radius:10px;padding:6px;
  border:1.5px solid var(--border);width:fit-content;margin-bottom:36px;flex-wrap:wrap}
.tab-btn{padding:9px 20px;border-radius:7px;border:none;background:transparent;
  font-family:'Hind',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;
  color:var(--muted);transition:background .2s,color .2s}
.tab-btn.active{background:var(--red);color:var(--white)}
.tab-panel{display:none}
.tab-panel.active{display:block}

.subject-table{width:100%;border-collapse:collapse;background:var(--white);
  border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.06)}
.subject-table thead tr{background:var(--red)}
.subject-table thead th{padding:14px 18px;text-align:left;color:var(--white);
  font-size:.8rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
.subject-table tbody tr{border-bottom:1px solid var(--border)}
.subject-table tbody tr:last-child{border-bottom:none}
.subject-table tbody tr:hover{background:var(--light)}
.subject-table tbody td{padding:13px 18px;font-size:.85rem;color:var(--text)}
.subject-table tbody td:first-child{font-weight:700;color:var(--dark)}

.exam-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px}
.exam-card{background:var(--white);border-radius:12px;padding:22px 20px;
  border:1.5px solid var(--border);box-shadow:0 2px 10px rgba(0,0,0,.05)}
.exam-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.exam-card h3{font-size:1rem;font-weight:700;color:var(--dark)}
.exam-badge{background:var(--red);color:var(--white);font-size:.68rem;font-weight:700;
  padding:3px 10px;border-radius:100px}
.exam-row{display:flex;justify-content:space-between;padding:8px 0;
  border-bottom:1px dashed var(--border);font-size:.82rem}
.exam-row:last-child{border-bottom:none}
.exam-row .er-label{color:var(--muted)}
.exam-row .er-val{font-weight:600;color:var(--dark)}

.result-info{background:var(--white);border-radius:14px;padding:28px;border:1.5px solid var(--border);margin-top:8px}
.result-info h3{font-family:'Cinzel',serif;font-size:1.2rem;color:var(--dark);margin-bottom:16px}
.grade-table{width:100%;border-collapse:collapse;margin-top:8px}
.grade-table th{background:var(--red);color:var(--white);padding:10px 14px;text-align:left;font-size:.8rem;letter-spacing:.04em}
.grade-table td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:.85rem}
.grade-table tr:last-child td{border:none}
.grade-table tr:hover td{background:var(--light)}

/* ══ CONTACT ══════════════════════════════════════ */
#contact-section{padding:70px 5%;background:var(--white);display:grid;grid-template-columns:1fr 1fr;gap:60px}
.contact-left h2{font-family:'Cinzel',serif;font-size:2rem;color:var(--dark);margin-bottom:16px}
.contact-left p{color:var(--muted);line-height:1.75;font-size:.92rem;margin-bottom:28px}
.c-items{display:flex;flex-direction:column;gap:14px}
.c-item{display:flex;align-items:flex-start;gap:14px}
.c-ic{min-width:42px;height:42px;background:var(--red);border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.c-text h4{font-size:.85rem;font-weight:700;margin-bottom:2px}
.c-text p{font-size:.8rem;color:var(--muted)}
.contact-form{background:var(--light);border-radius:16px;padding:32px 28px;border:1.5px solid var(--border)}
.contact-form h3{font-family:'Cinzel',serif;font-size:1.3rem;color:var(--dark);margin-bottom:20px}
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}
.fg label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--dark)}
.fg input,.fg select,.fg textarea{border:1.5px solid var(--border);border-radius:7px;padding:10px 13px;
  font-family:'Hind',sans-serif;font-size:.88rem;background:var(--white);outline:none;transition:border-color .2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--red)}
.fg textarea{min-height:80px;resize:vertical}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.submit-btn{width:100%;background:var(--red);color:var(--white);border:none;padding:13px;
  border-radius:8px;font-family:'Hind',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;
  transition:background .2s,transform .2s;letter-spacing:.04em;margin-top:4px}
.submit-btn:hover{background:var(--dark-red);transform:translateY(-2px)}

/* FOOTER */
footer{background:#0d0505;padding:48px 5% 20px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;padding-bottom:32px;
  border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:20px}
.footer-brand .fb-logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.footer-brand .fb-logo img{width:44px;height:44px;border-radius:50%;object-fit:cover}
.footer-brand .fb-logo span{font-family:'Cinzel',serif;color:var(--white);font-size:.95rem;font-weight:700}
.footer-brand p{color:rgba(255,255,255,.45);font-size:.82rem;line-height:1.75}
.footer-col h4{color:var(--white);font-size:.75rem;font-weight:700;letter-spacing:.1em;
  text-transform:uppercase;margin-bottom:12px}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px}
.footer-col ul li a{color:rgba(255,255,255,.45);text-decoration:none;font-size:.8rem;transition:color .2s}
.footer-col ul li a:hover{color:var(--gold)}
.footer-bottom{text-align:center;color:rgba(255,255,255,.3);font-size:.75rem}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:860px){
  .hero{grid-template-columns:1fr;min-height:auto;padding-top:90px}
  .hero-right{display:none}
  .about-strip{grid-template-columns:1fr}
  .about-strip img{display:none}
  .calendar-grid{grid-template-columns:1fr}
  #contact-section{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .nav-links a{padding:10px 8px;font-size:.72rem}
  .form-row-2{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- TICKER -->
<div class="ticker-wrap">
  <div class="ticker">
    <span>📢 Admissions Open for Session 2026–27 – Class 1 to 10</span>
    <span>🏆 Annual Prize Distribution Ceremony – 15 June 2026</span>
    <span>📅 Summer Vacation: 15 May – 30 June 2026</span>
    <span>📝 Half-Yearly Exam Schedule Published – Check Calendar</span>
    <span>🎨 Inter-School Drawing Competition – 20 June 2026</span>
    <span>📢 Admissions Open for Session 2026–27 – Class 1 to 10</span>
    <span>🏆 Annual Prize Distribution Ceremony – 15 June 2026</span>
    <span>📅 Summer Vacation: 15 May – 30 June 2026</span>
    <span>📝 Half-Yearly Exam Schedule Published – Check Calendar</span>
    <span>🎨 Inter-School Drawing Competition – 20 June 2026</span>
  </div>
</div>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="#" onclick="showSection('home')">
      <img src="data:image/jpeg;base64," alt="HOPS Logo"/>
      <div class="nav-logo-text">
        <div class="school-name">Hari Om Public School</div>
        <div class="school-sub">Pahalwanpur · Ghazipur</div>
      </div>
    </a>
    <div class="nav-links">
      <a href="#" class="active" onclick="showSection('home',this)">Home</a>
      <a href="#" onclick="showSection('announcements',this)">Notices</a>
      <a href="#" onclick="showSection('calendar',this)">Calendar</a>
      <a href="#" onclick="showSection('cocurricular',this)">Activities</a>
      <a href="#" onclick="showSection('academics',this)">Academics</a>
      <a href="#" onclick="showSection('contact',this)">Contact</a>
      <a href="#" class="nav-admit" onclick="showSection('contact',this)">Admissions →</a>
    </div>
  </div>
</nav>

<!-- ══ HOME ══════════════════════════════════════════ -->
<div id="sec-home" class="page-section active">

  <section class="hero">
    <div class="hero-left">
      <span class="hero-eyebrow">✦ Est. · Kishohari, Pahalwanpur, Ghazipur</span>
      <h1>Hari Om<br/>Public School</h1>
      <p class="hero-slogan">"Innovating and in Making of a New Generation"</p>
      <p class="hero-location">📍 Kishohari, Pahalwanpur, Ghazipur, Uttar Pradesh</p>
      <div class="hero-btns">
        <a href="#" class="btn-white" onclick="showSection('contact')">Apply for Admission</a>
        <a href="#" class="btn-ghost" onclick="showSection('academics')">View Academics</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-logo-circle">
        <img src="data:image/jpeg;base64," alt="Hari Om Public School Logo"/>
      </div>
      <div class="hero-cards">
        <div class="hero-card"><div class="hc-icon">📚</div><h3>Classes 1–10</h3><p>Full primary & secondary curriculum</p></div>
        <div class="hero-card"><div class="hc-icon">🏆</div><h3>Excellence</h3><p>Consistent board results</p></div>
        <div class="hero-card"><div class="hc-icon">🎭</div><h3>Activities</h3><p>Sports, arts & culture</p></div>
        <div class="hero-card"><div class="hc-icon">🌱</div><h3>Values</h3><p>Character & discipline</p></div>
      </div>
    </div>
  </section>

  <div class="stats-row">
    <div class="stat"><div class="n">600+</div><div class="l">Students</div></div>
    <div class="stat"><div class="n">30+</div><div class="l">Teachers</div></div>
