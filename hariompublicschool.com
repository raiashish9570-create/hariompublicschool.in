    <div id="tab-grading" class="tab-panel">
      <div class="result-info">
        <h3>Grading & Promotion Policy</h3>
        <table class="grade-table">
          <thead><tr><th>Marks Range</th><th>Grade</th><th>Remark</th><th>Promotion</th></tr></thead>
          <tbody>
            <tr><td>91–100%</td><td>A+ (Distinction)</td><td>Outstanding</td><td>✅ Promoted</td></tr>
            <tr><td>75–90%</td><td>A (First Division)</td><td>Excellent</td><td>✅ Promoted</td></tr>
            <tr><td>60–74%</td><td>B (Second Division)</td><td>Good</td><td>✅ Promoted</td></tr>
            <tr><td>45–59%</td><td>C (Third Division)</td><td>Satisfactory</td><td>✅ Promoted</td></tr>
            <tr><td>33–44%</td><td>D (Pass)</td><td>Needs Improvement</td><td>✅ Promoted with conditions</td></tr>
            <tr><td>Below 33%</td><td>F (Fail)</td><td>Improvement Required</td><td>❌ Detained / Re-exam</td></tr>
          </tbody>
        </table>
        <p style="margin-top:16px;font-size:.82rem;color:var(--muted);line-height:1.7">
          <strong>Attendance:</strong> Minimum 75% attendance is mandatory to appear in annual examinations. Students with less than 75% attendance will not be permitted to sit for exams without prior approval of the Principal.<br/><br/>
          <strong>Conduct:</strong> Disciplinary action including detention may be taken irrespective of academic performance in cases of gross misconduct.
        </p>
      </div>
    </div>

